{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for StarTalk",
  "windows": ["main", "pill", "popover"],
  "permissions": [
    "core:default",
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "osascript",
          "cmd": "osascript",
          "args": true
        }
      ]
    },
    "store:default",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select"
  ]
}
